# Copy this to .env.production after fetching secrets from Vault (do NOT commit .env.production)
MCP_GATEWAY_KEY=sk_prod_replace_me
POSTGRES_DSN=postgres://postgres:postgres@postgres:5432/mcp
GITHUB_TOKEN=ghp_xxx
NOTION_TOKEN=notion_xxx
FIGMA_TOKEN=figma_xxx
# Optional pool settings
PG_MIN_CONN=1
PG_MAX_CONN=5
PG_STATEMENT_TIMEOUT_MS=5000
PG_MAX_ROWS=1000
