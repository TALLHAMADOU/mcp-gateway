# --- Gateway core ---
MCP_GATEWAY_KEY=sk_local_example      # bearer key required on /v1/* and /mcp
MCP_GATEWAY_URL=http://localhost:8080
ADMIN_KEY=                            # optional: protects /v1/admin/register
FS_ROOT=.                             # filesystem sandbox root (realpath-contained)

# --- Databases (read-only) ---
POSTGRES_DSN=                         # postgres://user:pass@host:5432/db
PG_STATEMENT_TIMEOUT_MS=5000
PG_MAX_ROWS=1000

# --- SaaS proxies (optional tokens) ---
GITHUB_TOKEN=
NOTION_TOKEN=
FIGMA_TOKEN=

# --- Office / bureautique ---
OFFICE_OUTPUT_DIR=                    # defaults to <FS_ROOT>/output
GOOGLE_ACCESS_TOKEN=                  # OAuth2 token for Drive/Docs/Sheets/Slides
MS_GRAPH_TOKEN=                       # Microsoft Graph token for OneDrive/Word/Excel
