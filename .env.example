# --- Gateway core ---
MCP_GATEWAY_KEY=sk_local_example      # bearer key (full access) for /v1/* and /mcp
# Optional extra keys with per-scope access (JSON). A scope is the path segment
# after /v1/ (fs, github, postgres, plugins, ...) or "dashboard"; "*" = all.
# MCP_GATEWAY_KEYS={"sk_reader":["fs","github"],"sk_admin":["*"]}
MCP_GATEWAY_URL=http://localhost:8080
ADMIN_KEY=                            # optional: protects /v1/admin/register and /v1/audit
FS_ROOT=.                             # filesystem sandbox root (realpath-contained)
AUDIT_LOG_PATH=data/audit.log         # append-only JSONL audit trail (rotated, 5MB x5)

# --- Upstream MCP servers bridge (cas C) ---
MCP_SERVERS_CONFIG=mcp_servers.yaml   # config of third-party MCP servers to bridge
MCP_UPSTREAM_ENABLE_STDIO=            # =1 to allow stdio servers (spawns local processes)

# --- Databases (read-only) ---
POSTGRES_DSN=                         # postgres://user:pass@host:5432/db
PG_STATEMENT_TIMEOUT_MS=5000
PG_MAX_ROWS=1000

# --- SaaS proxies (optional tokens) ---
GITHUB_TOKEN=
NOTION_TOKEN=
FIGMA_TOKEN=

# --- Office / bureautique ---
OFFICE_OUTPUT_DIR=                    # defaults to <FS_ROOT>/output
OFFICE_USE_CONTAINER=                 # =1 to run LibreOffice convert in an isolated container
OFFICE_CONTAINER_IMAGE=               # image providing soffice (default: libreoffice:latest)
OFFICE_CONTAINER_MEM=                 # container memory limit (default: 512m)

# Cloud auth: either a static access token (expires ~1h) OR refresh creds below
# (auto-refreshed by the gateway, recommended for long-running deployments).
GOOGLE_ACCESS_TOKEN=                  # static OAuth2 token for Drive/Docs/Sheets/Slides
GOOGLE_CLIENT_ID=                     # refresh flow: OAuth client id
GOOGLE_CLIENT_SECRET=                 # refresh flow: OAuth client secret
GOOGLE_REFRESH_TOKEN=                 # refresh flow: long-lived refresh token
MS_GRAPH_TOKEN=                       # static Microsoft Graph token for OneDrive/Word/Excel
MS_TENANT_ID=                         # refresh flow: Azure AD tenant id
MS_CLIENT_ID=                         # refresh flow: app (client) id
MS_CLIENT_SECRET=                     # refresh flow: client secret
MS_REFRESH_TOKEN=                     # optional: delegated refresh token (else client_credentials)
